    {
      "parameters": {
        "jsCode": "// Get current time\nconst now = new Date();\n\n// Iterate through all loaded items\nfor (const item of items) {\n  const lastActiveString = item.json[\"Last active date\"];\n\n  // Error handling: If cell is empty (never been active)\n  if (!lastActiveString) {\n    item.json.differenceInDays = 999; // Set a fictional high number\n    item.json.shouldTrigger = true;   // Should trigger a message\n    continue;\n  }\n\n  // Convert sheet text to date\n  const lastActiveDate = new Date(lastActiveString);\n\n  // Calculate difference in milliseconds\n  const differenceInMs = now - lastActiveDate;\n\n  // Convert milliseconds to days (1000ms * 60s * 60min * 24h)\n  const differenceInDays = differenceInMs / (1000 * 60 * 60 * 24);\n\n  // Save results back to data for the next node\n  item.json.differenceInDays = parseFloat(differenceInDays.toFixed(2)); // Round to 2 decimal places\n  item.json.shouldTrigger = differenceInDays > 2; // TRUE if more than 2 days\n}\n\nreturn items;"
      },
