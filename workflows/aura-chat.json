      "parameters": {
        "jsCode": "// Process all items\nfor (const item of items) {\n  // If binary data exists in 'data' variable\n  if (item.binary && item.binary.data) {\n    // Manually set MIME type to audio/ogg\n    item.binary.data.mimeType = 'audio/ogg';\n    // Also set file extension for safety\n    item.binary.data.fileExtension = 'oga';\n    item.binary.data.fileName = 'voice_message.oga';\n  }\n}\n\nreturn items;"
      },
